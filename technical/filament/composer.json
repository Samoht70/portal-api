{
    "name": "technical/filament",
    "description": "Filament admin panel infrastructure.",
    "type": "layer",
    "version": "1.0.0",
    "require": {
        "xefi/laravel-osdd": "*",
        "filament/filament": "^5.0",
        "functional/organizations": "*",
        "functional/applications": "*",
        "functional/users": "*",
        "functional/subscriptions": "*"
    },
    "autoload": {
        "psr-4": {
            "Technical\\Filament\\": "src/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "providers": [
                "Technical\\Filament\\Providers\\FilamentServiceProvider",
                "Technical\\Filament\\Providers\\AdminPanelProvider"
            ]
        }
    }
}
