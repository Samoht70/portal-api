meta {
  name: login
  type: http
  seq: 2
}

post {
  url: {{API_URL}}/{{resource}}/login
  body: json
  auth: inherit
}

body:json {
  {
    "email": "{{email}}",
    "password": "{{password}}"
  }
}

script:post-response {
  if (res.status === 200) {
    const accessToken = res.body.access_token;
    bru.setGlobalEnvVar('jwt', accessToken);
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
