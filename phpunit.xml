<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd" bootstrap="vendor/autoload.php" colors="true">
  <testsuites>
    <testsuite name="technical/authentication">
      <directory>technical/authentication/tests</directory>
    </testsuite>
    <testsuite name="technical/oauth-server">
      <directory>technical/oauth-server/tests</directory>
    </testsuite>
    <testsuite name="functional/subscriptions">
      <directory>functional/subscriptions/tests</directory>
    </testsuite>
    <testsuite name="functional/organizations">
      <directory>functional/organizations/tests</directory>
    </testsuite>
    <testsuite name="dailyapps/event-distribution">
      <directory>dailyapps/event-distribution/tests</directory>
    </testsuite>
    <testsuite name="functional/users">
      <directory>functional/users/tests</directory>
    </testsuite>
    <testsuite name="functional/applications">
      <directory>functional/applications/tests</directory>
    </testsuite>
  </testsuites>
  <source>
    <include>
      <directory>app</directory>
    </include>
    <exclude>
      <directory suffix=".php">**/database/migrations</directory>
    </exclude>
  </source>
  <php>
    <env name="APP_ENV" value="testing"/>
    <env name="APP_MAINTENANCE_DRIVER" value="file"/>
    <env name="BCRYPT_ROUNDS" value="4"/>
    <env name="BROADCAST_CONNECTION" value="null"/>
    <env name="CACHE_STORE" value="array"/>
    <env name="DB_DATABASE" value="portal_api_test"/>
    <env name="DB_URL" value=""/>
    <env name="MAIL_MAILER" value="array"/>
    <env name="QUEUE_CONNECTION" value="sync"/>
    <env name="SESSION_DRIVER" value="array"/>
    <env name="PULSE_ENABLED" value="false"/>
    <env name="TELESCOPE_ENABLED" value="false"/>
    <env name="NIGHTWATCH_ENABLED" value="false"/>
  </php>
</phpunit>
