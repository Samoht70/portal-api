{
    "name": "functional/organizations",
    "description": "",
    "type": "layer",
    "version": "1.0.0",
    "require": {
        "xefi/laravel-osdd": "*"
    },
    "autoload": {
        "psr-4": {
            "Functional\\Organizations\\": "src/",
            "Functional\\Organizations\\Database\\Seeders\\": "database/seeders/",
