{
    "name": "dailyapps/portal-shared-schema",
    "description": "Canonical identity/org core schema (Blueprint macros) shared between the portal mother app and its child replicas.",
    "type": "layer",
    "version": "1.0.0",
    "require": {
        "xefi/laravel-osdd": "*"
    },
    "autoload": {
        "psr-4": {
            "Dailyapps\\PortalShared\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dailyapps\\PortalShared\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "providers": [
                "Dailyapps\\PortalShared\\Providers\\PortalSharedServiceProvider"
            ]
        }
    }
}
