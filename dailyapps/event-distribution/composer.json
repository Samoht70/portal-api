{
    "name": "dailyapps/event-distribution",
    "description": "Event distribution for the data-sync pipeline. Currently holds only the recipient-resolution contract; outbox, relay and jobs land in a later increment.",
    "type": "layer",
    "version": "1.0.0",
    "require": {
        "xefi/laravel-osdd": "*"
    },
    "autoload": {
        "psr-4": {
            "Dailyapps\\EventDistribution\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dailyapps\\EventDistribution\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "providers": [
                "Dailyapps\\EventDistribution\\Providers\\EventDistributionServiceProvider"
            ]
        }
    }
}
